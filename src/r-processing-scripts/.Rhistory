head(me_all_ins)
nrow(me_all_ins)
nrow(me_all_ins[me_all_ins$fraction => 0.99,])
nrow(me_all_ins[me_all_ins$fraction >= 0.99,])
table(me_all_ins$pos[me_all_ins$fraction >= 0.99])
nrow(me_all_ins[me_all_ins$fraction >= 0.5,])
table(me_all_ins$pos[me_all_ins$fraction >= 0.5])
nchar(me_all_ins$inserted[me_all_ins$fraction >= 0.5])
