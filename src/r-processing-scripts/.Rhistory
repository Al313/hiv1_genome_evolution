me_all_dels <- read.csv(file = "/Users/alimos313/Documents/studies/phd/research/seq-genome-proj/data/processed-data/mutations/all_dels.csv", sep = ",", header = T, stringsAsFactors = F)
head(me_all_dels)
nrow(me_all_dels)
